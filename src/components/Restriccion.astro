<!-- ═══════════════════════════════════════════════════════════ --><!-- 👥 SECCIÓN: ACOMPAÑANTES (SIN NIÑOS)                        --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-20 pb-10 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- 📇 CARD DE ACOMPAÑANTES -->
        <div class="flex justify-center">
            <div class="relative w-[280px]" id="card-acompanantes">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-acompanantes">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-acompanantes"
                >
                    <!-- IMAGEN DE FONDO -->
                    <img
                        src="/imagenes/fondoplomo.png"
                        alt="Fondo acompañantes"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <!-- Contenido de la card -->
                    <div
                        class="relative px-4 pt-16 pb-12 z-10 flex flex-col items-center justify-center min-h-[200px]"
                    >
                        <!-- ICONO -->
                        <div class="mb-4">
                            <div
                                class="w-16 h-16 mx-auto icono-restriccion-rosa"
                            >
                            </div>
                        </div>

                        <!-- TÍTULO -->
                        <div class="text-center mb-2">
                            <h2
                                class="font-great-vibes text-[2rem] text-[#8c6f5a]"
                            >
                                Una Velada Para Adultos
                            </h2>
                        </div>

                        <!-- TEXTO PRINCIPAL -->
                        <div class="text-center" id="texto-acompanantes">
                            <p
                                class="font-crimson text-xl leading-relaxed text-[#b76e79]"
                            >
                                Para disfrutar de esta noche sin preocupaciones,
                                hemos preparado una celebración pensada
                                especialmente para los adultos.
                                <br />
                                Agradecemos de corazón su comprensión y cariño.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP - SOLO AL BAJAR                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            // Animación del botón decorativo
            gsap.fromTo(
                "#boton-decorativo-acompanantes",
                {
                    opacity: 0,
                    scale: 0,
                    rotation: -180,
                },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-acompanantes",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación de la card
            gsap.fromTo(
                "#card-principal-acompanantes",
                {
                    opacity: 0,
                    y: 50,
                    scale: 0.95,
                },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-acompanantes",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación del texto
            gsap.fromTo(
                "#texto-acompanantes",
                {
                    opacity: 0,
                    y: 20,
                },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.3,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-acompanantes",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );
        });
    }
</script>

<style>
    /* Icono de restricción - palo de rosa */
    .icono-restriccion-rosa {
        background-color: #b76e79;
        -webkit-mask-image: url("/imagenes/restriccion.png");
        mask-image: url("/imagenes/restriccion.png");
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
    }
</style>
