<!-- ═══════════════════════════════════════════════════════════ --><!-- 📖 SECCIÓN: CITA BÍBLICA                                    --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full py-6 sm:py-10" id="seccion-cita">
    <div class="max-w-6xl mx-auto px-6 sm:px-6 lg:px-8">
        <div class="flex flex-col items-center text-center" id="cita-container">
            <p
                class="font-great-vibes text-2xl sm:text-3xl md:text-4xl text-[#8c6f5a] leading-relaxed"
                id="cita-texto"
            >
                &ldquo;Más valen dos que uno, porque obtienen más fruto de su
                esfuerzo. Si caen, el uno levanta al otro.&rdquo;
            </p>
            <p
                class="mt-3 font-crimson text-xs sm:text-sm uppercase tracking-[0.3em] text-[#b76e79]"
                id="cita-referencia"
            >
                Eclesiastés 4:9-10
            </p>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        gsap.fromTo(
            "#cita-texto",
            { opacity: 0, y: 20 },
            {
                opacity: 1,
                y: 0,
                duration: 1.4,
                ease: "sine.out",
                scrollTrigger: {
                    trigger: "#cita-container",
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );

        gsap.fromTo(
            "#cita-referencia",
            { opacity: 0, y: 10 },
            {
                opacity: 1,
                y: 0,
                duration: 1,
                ease: "sine.out",
                delay: 0.4,
                scrollTrigger: {
                    trigger: "#cita-container",
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );
    });
</script>
