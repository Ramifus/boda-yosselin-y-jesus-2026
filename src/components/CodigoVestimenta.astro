<!-- ═══════════════════════════════════════════════════════════ --><!-- 👔 SECCIÓN: DRESS CODE                                      --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-10 pb-10 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- 📇 CARD DE DRESS CODE -->
        <div class="flex justify-center">
            <div class="relative w-[300px]" id="card-dresscode">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-dresscode">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-dresscode"
                >
                    <!-- IMAGEN DE FONDO -->
                    <img
                        src="/imagenes/fondorojo.png"
                        alt="Fondo dress code"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <!-- Contenido de la card -->
                    <div class="relative px-2 pt-16 pb-10 z-10">
                        <!-- TÍTULO PRINCIPAL -->
                        <div class="text-center mb-6" id="titulo-dresscode">
                            <h2
                                class="font-great-vibes text-[2.5rem] text-[#8c6f5a] leading-none mb-2"
                            >
                                Dress Code
                            </h2>
                            <p
                                class="font-crimson text-lg uppercase tracking-widest text-[#b76e79] font-semibold"
                            >
                                FORMAL – ELEGANTE
                            </p>
                        </div>

                        <!-- SECCIÓN: ELLOS Y ELLAS -->
                        <div
                            class="flex justify-center gap-4 mb-2"
                            id="seccion-vestimenta"
                        >
                            <!-- ELLOS -->
                            <div class="text-center flex-1" id="seccion-ellos">
                                <div class="mb-3">
                                    <div class="relative w-[43px] mx-auto">
                                        <img
                                            src="/imagenes/trajehombre.png"
                                            alt="Traje Formal"
                                            class="w-full h-auto invisible"
                                        />
                                        <div class="absolute inset-0 icono-traje-hombre-rosa"></div>
                                    </div>
                                </div>
                                <h3
                                    class="font-crimson text-lg uppercase tracking-wider text-[#b76e79] font-bold mb-2"
                                >
                                    CABALLEROS
                                </h3>
                            </div>

                            <!-- ELLAS -->
                            <div class="text-center flex-1" id="seccion-ellas">
                                <div class="mb-3">
                                    <div class="relative w-20 mx-auto">
                                        <img
                                            src="/imagenes/trajemujer.png"
                                            alt="Vestido Largo"
                                            class="w-full h-auto invisible"
                                        />
                                        <div class="absolute inset-0 icono-traje-mujer-rosa"></div>
                                    </div>
                                </div>
                                <h3
                                    class="font-crimson text-lg uppercase tracking-wider text-[#b76e79] font-bold mb-2"
                                >
                                    DAMAS
                                </h3>
                            </div>
                        </div>

                        <!-- COLORES RESERVADOS PARA LOS NOVIOS -->
                        <div class="text-center mt-2" id="seccion-colores">
                            <p
                                class="font-crimson text-sm uppercase tracking-widest text-[#b76e79]/70 mb-1"
                            >
                                Colores reservados para los novios
                            </p>
                            <p
                                class="font-crimson text-lg uppercase tracking-widest text-[#b76e79] font-bold"
                            >
                                Palo de Rosa, Blanco y Beige
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎨 ESTILOS PARA LOS ICONOS                                  -->
<!-- ═══════════════════════════════════════════════════════════ -->
<style>
    /* Iconos de dress code - palo de rosa */
    .icono-traje-hombre-rosa,
    .icono-traje-mujer-rosa {
        background-color: #b76e79;
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
    }

    .icono-traje-hombre-rosa {
        -webkit-mask-image: url("/imagenes/trajehombre.png");
        mask-image: url("/imagenes/trajehombre.png");
    }

    .icono-traje-mujer-rosa {
        -webkit-mask-image: url("/imagenes/trajemujer.png");
        mask-image: url("/imagenes/trajemujer.png");
    }
</style>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP - SOLO AL BAJAR (SIN PERDER CONTENIDO) -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            // Animación del botón decorativo
            gsap.fromTo(
                "#boton-decorativo-dresscode",
                {
                    opacity: 0,
                    scale: 0,
                    rotation: -180,
                },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-dresscode",
                        start: "top 80%",
                        toggleActions: "play none none reset", // ✅ Solo play al bajar
                    },
                },
            );

            // Animación de la card
            gsap.fromTo(
                "#card-principal-dresscode",
                {
                    opacity: 0,
                    y: 50,
                    scale: 0.95,
                },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-dresscode",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación del título
            gsap.fromTo(
                "#titulo-dresscode",
                {
                    opacity: 0,
                    y: -20,
                },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-dresscode",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación ellos (desde la izquierda)
            gsap.fromTo(
                "#seccion-ellos",
                {
                    opacity: 0,
                    x: -30,
                },
                {
                    opacity: 1,
                    x: 0,
                    duration: 0.8,
                    delay: 0.2,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-dresscode",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación ellas (desde la derecha)
            gsap.fromTo(
                "#seccion-ellas",
                {
                    opacity: 0,
                    x: 30,
                },
                {
                    opacity: 1,
                    x: 0,
                    duration: 0.8,
                    delay: 0.2,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-dresscode",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación de colores
            gsap.fromTo(
                "#seccion-colores",
                {
                    opacity: 0,
                    y: 20,
                },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.6,
                    delay: 0.4,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-dresscode",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación nota final
            gsap.fromTo(
                "#nota-final",
                {
                    opacity: 0,
                    y: 20,
                },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.6,
                    delay: 0.6,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-dresscode",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );
        });
    }
</script>
