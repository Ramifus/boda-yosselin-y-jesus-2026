<!-- 🎬 ANIMACIONES CON GSAP - SOLO AL BAJAR                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            // Animación del botón decorativo
            gsap.fromTo(
                "#boton-decorativo-fotos",
                {
                    opacity: 0,
                    scale: 0,
                    rotation: -180,
                },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación de la card
            gsap.fromTo(
                "#card-principal-fotos",
                {
                    opacity: 0,
                    y: 50,
                    scale: 0.95,
                },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación del icono de cámara
            gsap.fromTo(
                "#icono-camara",
                {
                    opacity: 0,
                    scale: 0.5,
                    rotation: -10,
                },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 0.8,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación del título
            gsap.fromTo(
                "#titulo-fotos",
                {
                    opacity: 0,
                    y: -20,
                },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.2,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación del texto
            gsap.fromTo(
                "#texto-fotos",
                {
                    opacity: 0,
                    y: 20,
                },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.4,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación del botón
            gsap.fromTo(
                "#boton-compartir-fotos",
                {
                    opacity: 0,
                    y: 20,
                },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.6,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );
        });
    }
</script>

